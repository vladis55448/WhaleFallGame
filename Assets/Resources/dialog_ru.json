[
    {
        "Id": "Capsule",
        "Messages": [
            {
                "Text": "Пилюля.",
                "EventId": "none",
                "Character": "Mind"
            },
            {
                "Text": "Выглядит страшно, но выполняет свою работу.",
                "EventId": "none",
                "Character": "Mind"
            }
        ]
    },
    {
        "Id": "Deccent_Block",
        "Messages": [
            {
                "Text": "Лучше сначала поговорить с крановщиком",
                "EventId": "none",
                "Character": "Mind"
            }
        ]
    },
    {
        "Id": "Deccent_0",
        "Messages": [
            {
                "Text": "Доброе утро, Александр",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Здравствуйте",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Вы проверили фиксаторы?",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Да",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Ремни затянуты?",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Да, всё впорядке",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Сиденье комфортно?",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Давайте уже приступать",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Да, конечно.",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "По процедуре вы должны дать добровольное согласие.",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Пожалуйста представьтесь, а затем скажите, что вы согласны на транспортировку к рабочему месту.",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Вы уже привязали меня - зачем…",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Не я писал правила",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Хорошо.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Я - Вершинин Александр Сергеевич.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Даю своё персональное согласие на транспортировку к рабочему месту.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Формальности закончены? Можно уже меня опустить?",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Конечно, удачной вахты, Александр.",
                "EventId": "none",
                "Character": "TopManager"
            }
        ]
    },
    {
        "Id": "Deccent_1",
        "Messages": [
            {
                "Text": "Привет, коллега, нормально добрался?",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Здравствуйте, всё в порядке.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Да ладно тебе, всем страшно в первый раз.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Ты ж на пюлюле мог в пасть кита спускаться.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Мне сказали, что они так близко не подплывают.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Ха, да начальство куча чего болтает.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Ладно, всё ты крепыш.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Спасибо",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Димку до тебя жутко разнесло на его первом спуске.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "А можно меня уже отстегнуть?",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Ты меня сам заболтал.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Щас",
                "EventId": "none",
                "Character": "Crane"
            }
        ]
    },
    {
        "Id": "Deccent_3",
        "Messages": [
            {
                "Text": "Точно, я забыл представиться.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Я Петр Семеныч - отвечаю за лифт сообщения и склады.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Приятно, я Александр - буду лечащим врачом на станции.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Так что при любых телесных,или ментальных проблемах...",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Обращайтесь.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Не обижайся, Сань, но у нас нормальные люди - депрессию лечат работой.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "В любом случае - моя работа следить за состоянием команды.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Жесть, ты сухой как чебуслоп.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Ну ладно, Александр - у меня ещё есть чем заняться.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "А тебе лучше навестить шефа.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "А где его найти?",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Этажом выше - рядом с лабораторией. Быстро разберешься.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Спасибо. Я пойду.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Удачи, Александр.",
                "EventId": "none",
                "Character": "Crane"
            }
        ]
    }
]