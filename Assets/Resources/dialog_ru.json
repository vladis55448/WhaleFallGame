[
    {
        "Id": "Capsule",
        "Messages": [
            {
                "Text": "Пилюля.",
                "EventId": "none",
                "Character": "Mind"
            },
            {
                "Text": "Выглядит страшно, но выполняет свою работу.",
                "EventId": "none",
                "Character": "Mind"
            }
        ]
    },
    {
        "Id": "Not now",
        "Messages": [
            {
                "Text": "Не сейчас",
                "EventId": "none",
                "Character": "Mind"
            }
        ]
    },
    {
        "Id": "Deccent_Block",
        "Messages": [
            {
                "Text": "Лучше сначала поговорить с крановщиком",
                "EventId": "none",
                "Character": "Mind"
            }
        ]
    },
    {
        "Id": "Deccent_0",
        "Messages": [
            {
                "Text": "Доброе утро, Александр",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Здравствуйте",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Вы проверили фиксаторы?",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Да",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Ремни затянуты?",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Да, всё впорядке",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Сиденье комфортно?",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Давайте уже приступать",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Да, конечно.",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "По процедуре вы должны дать добровольное согласие.",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Пожалуйста представьтесь, а затем скажите, что вы согласны на транспортировку к рабочему месту.",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Вы уже привязали меня - зачем…",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Не я писал правила",
                "EventId": "none",
                "Character": "TopManager"
            },
            {
                "Text": "Хорошо.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Я - Вершинин Александр Сергеевич.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Даю своё персональное согласие на транспортировку к рабочему месту.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Формальности закончены? Можно уже меня опустить?",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Конечно, удачной вахты, Александр.",
                "EventId": "none",
                "Character": "TopManager"
            }
        ]
    },
    {
        "Id": "Deccent_1",
        "Messages": [
            {
                "Text": "Привет, коллега, нормально добрался?",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Здравствуйте, всё в порядке.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Да ладно тебе, всем страшно в первый раз.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Ты ж на пюлюле мог в пасть кита спускаться.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Мне сказали, что они так близко не подплывают.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Ха, да начальство куча чего болтает.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Ладно, всё ты крепыш.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Спасибо",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Димку до тебя жутко разнесло на его первом спуске.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "А можно меня уже отстегнуть?",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Ты меня сам заболтал.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Щас",
                "EventId": "none",
                "Character": "Crane"
            }
        ]
    },
    {
        "Id": "Deccent_3",
        "Messages": [
            {
                "Text": "Точно, я забыл представиться.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Я Петр Семеныч - отвечаю за лифт сообщения и склады.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Приятно, я Александр - буду лечащим врачом на станции.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Так что при любых телесных,или ментальных проблемах...",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Обращайтесь.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Не обижайся, Сань, но у нас нормальные люди - депрессию лечат работой.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "В любом случае - моя работа следить за состоянием команды.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Жесть, ты сухой как чебуслоп.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Ну ладно, Александр - у меня ещё есть чем заняться.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "А тебе лучше навестить шефа.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "А где его найти?",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Этажом выше - рядом с лабораторией. Быстро разберешься.",
                "EventId": "none",
                "Character": "Crane"
            },
            {
                "Text": "Спасибо. Я пойду.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Удачи, Александр.",
                "EventId": "none",
                "Character": "Crane"
            }
        ]
    },
    {
        "Id": "CapGreet",
        "Messages": [
            {
                "Text": "Можно войти?",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Да-да, можно.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Хорошо.",
                "EventId": "OpenDoor",
                "Character": "Hero"
            },
            {
                "Text": "Здравствуйте.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "О, твоя капсула уже прибыла.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Прости, засиделся за бумажками и не успел тебя встретить лично.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Ничего, Петр Семенович подсказал как до вас дойти.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Ну хорошо, тогда заходи, не блокируй другим проход.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Да, конечно",
                "EventId": "MoveCloser",
                "Character": "Hero"
            },
            {
                "Text": "Давай сначала нормально тебя оформим, потом тебе поясню некоторые правила.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Прeдставься пожалуйста.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Меня зовут Вершинин Александр Сергеевич.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "И меня отправили на эту станцию вахтовым врачом на срок в один год.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Так ты ещё студент?",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Уже нет.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Но ещё не врач?",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Ещё нет...",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Теперь специальная практика обязательна для всех.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Вон онон как.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Тебе хоть платят за это?",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Мне сказали, что здесь за работу бесплатно кормят.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Понятно. Свой бесплатный слоп ты точно получишь.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "За работу конечно.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Ну чтож, давай теперь я представлюсь - Дубох Михаил Иванович.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Приятно познакомиться.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Конечно-конечно.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Так вот, Александр - вкратце расскажу тебе об работе на станции.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Дело у нас трудное, а ещё крайне опасное.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "И для тела, и для души.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Так что попрошу тебя осматривать и разговаривать с коллегами после каждой их смены.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "В первую очередь следи за нашими дайверамию.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Им особо тяжело - вид гниющей мегафауны плохо сказывается на рассудке.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Так что отнесись к ним с пониманием.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Я постараюсь.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Хорошо. Ещё отдельно объясню тебе режим работы станции.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Хоть здесь и не видно солнца, мы всё равно делим день на циклы.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Днем работа, ночью сон. Без обсуждений.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Нарушение режима тут же будет отражено в личном деле.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Подробности будут в уставе, очень советую почитать.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Ну и на последок от меня.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Всегда закрывай двери, чтобы не блокировать каридоры.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "И экономь свет. Как видишь - у нас даже на свет строгий лимит.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Каждый килловатт на счету.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Хорошо, запомню.",
                "EventId": "none",
                "Character": "Hero"
            },
            {
                "Text": "Все так говорят, но понимают после первой затресчены.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "А некоторые после десятой...",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Ладно, не буду тебя дальше держать - вот тебе ключ от твоей комнаты.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Иди на этаж выше, отохни.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Потом жду тебя в мед кабинете через стену.",
                "EventId": "none",
                "Character": "Cap"
            },
            {
                "Text": "Ладно, постараюсь не задерживаться.",
                "EventId": "none",
                "Character": "Hero"
            }
        ]
    }
]